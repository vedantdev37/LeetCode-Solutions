class Solution:
    def arrayRankTransform(self, arr: list[int]) -> list[int]:
        # Step 1 & 2: Get unique elements and sort them
        sorted_unique = sorted(set(arr))
        
        # Step 3: Create a map to store the rank of each element
        # enumerate gives us (0, smallest), (1, next_smallest), etc.
        rank_map = {num: rank + 1 for rank, num in enumerate(sorted_unique)}
        
        # Step 4: Map original array elements to their ranks
        return [rank_map[num] for num in arr]
