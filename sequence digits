class Solution:
    def sequentialDigits(self, low: int, high: int) -> list[int]:
        # Base string containing all possible sequential digits
        seq = "123456789"
        result = []
        
        # The number of digits for the minimum and maximum possible bounds
        low_len = len(str(low))
        high_len = len(str(high))
        
        # Iterate through all possible lengths of the sequential numbers
        for length in range(low_len, high_len + 1):
            # Iterate through the starting index of the substring
            for start in range(10 - length):
                # Extract the substring and convert it back to an integer
                num = int(seq[start:start + length])
                
                # Check if it falls within the required range
                if low <= num <= high:
                    result.append(num)
                    
        return result
